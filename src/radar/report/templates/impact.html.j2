<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>security-radar — Impact Report</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;background:#f5f7fa;color:#2c3e50;padding:2rem}
.header{background:linear-gradient(135deg,#1a4a2f 0%,#27ae60 100%);color:white;padding:24px 32px;border-radius:10px;margin-bottom:24px}
.header h1{font-size:1.5rem;margin-bottom:4px}
.header .meta{font-size:13px;opacity:.75}
.cards{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:24px}
.card{border-radius:6px;padding:16px 24px;min-width:120px;text-align:center}
.card .num{font-size:2rem;font-weight:800}
.card .lbl{font-size:12px;font-weight:600;opacity:.8}
.panel{background:white;border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,.08);overflow:hidden;margin-bottom:20px}
.panel-header{padding:14px 20px;border-bottom:1px solid #e8ecf0;font-weight:700;font-size:15px;display:flex;align-items:center;gap:8px}
table{width:100%;border-collapse:collapse}
th,td{border-bottom:1px solid #eef1f5;padding:10px 14px;text-align:left;font-size:13px}
th{background:#f0f3f7;font-size:12px;text-transform:uppercase;color:#7f8c8d;font-weight:700}
tr:hover{background:#f8fafc}
code{background:#f0f3f7;padding:1px 5px;border-radius:3px;font-size:12px;color:#2471a3}
.changed{color:#c0392b;font-weight:700}
.approx{color:#d68910}
.mermaid-box{padding:1.5rem;overflow-x:auto;background:#fafafa;border-top:1px solid #eee}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700}
.badge-changed{background:#fde8e8;color:#c0392b;border:1px solid #e74c3c}
.badge-route{background:#e8f8e8;color:#1e8449;border:1px solid #27ae60}
.badge-fn{background:#eaf0ff;color:#1a3a8f;border:1px solid #3498db}
.badge-finding{background:#fde8e8;color:#c0392b;border:1px solid #e74c3c}
footer{text-align:center;color:#95a5a6;font-size:12px;margin-top:24px}
</style>
</head>
<body>

<div class="header">
  <h1>📡 security-radar — Blast Radius Report</h1>
  <div class="meta">
    {{ result.stats.functions_affected }} functions affected &nbsp;·&nbsp;
    {{ result.stats.apis_affected }} APIs &nbsp;·&nbsp;
    max depth {{ result.stats.max_depth }}
    {% if result.stats.approximate %} &nbsp;·&nbsp; {{ result.stats.approximate }} approximate edges{% endif %}
  </div>
</div>

<div class="cards">
  <div class="card" style="background:#fde8e8;border-left:5px solid #c0392b">
    <div class="num" style="color:#c0392b">{{ result.changed | length }}</div>
    <div class="lbl" style="color:#c0392b">CHANGED</div>
  </div>
  <div class="card" style="background:#eaf4fb;border-left:5px solid #2471a3">
    <div class="num" style="color:#2471a3">{{ result.stats.functions_affected }}</div>
    <div class="lbl" style="color:#2471a3">AFFECTED</div>
  </div>
  <div class="card" style="background:#e8f8e8;border-left:5px solid #27ae60">
    <div class="num" style="color:#27ae60">{{ result.stats.apis_affected }}</div>
    <div class="lbl" style="color:#27ae60">ROUTES</div>
  </div>
  <div class="card" style="background:#fefaf0;border-left:5px solid #d68910">
    <div class="num" style="color:#d68910">{{ result.stats.approximate }}</div>
    <div class="lbl" style="color:#d68910">APPROXIMATE</div>
  </div>
</div>

<div class="panel">
  <div class="panel-header">🔴 Changed Functions</div>
  <table>
    <thead><tr><th>Function</th><th>File</th><th>Routes</th><th>Feature</th></tr></thead>
    <tbody>
    {% for item in result.changed %}
    <tr>
      <td><code class="changed">{{ item.name }}</code>
        {% if item.findings %}<span class="badge badge-finding">⚠ {{ item.findings | length }} finding{{ "s" if item.findings | length != 1 else "" }}</span>{% endif %}
      </td>
      <td><code>{{ item.file }}:{{ item.line }}</code></td>
      <td>{{ item.routes | join(", ") or "—" }}</td>
      <td>{{ item.feature or "(unmapped)" }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<div class="panel">
  <div class="panel-header">⚡ Affected Functions &amp; Routes</div>
  <table>
    <thead><tr><th>Name</th><th>Kind</th><th>File</th><th>Depth</th><th>Confidence</th></tr></thead>
    <tbody>
    {% for item in result.affected %}
    <tr>
      <td>
        {% if item.kind == "route" %}
        <span class="badge badge-route">ROUTE</span>
        {% else %}
        <span class="badge badge-fn">fn</span>
        {% endif %}
        &nbsp;<code>{{ item.name }}</code>
        {% if item.findings %}<span class="badge badge-finding">⚠ {{ item.findings | length }} finding{{ "s" if item.findings | length != 1 else "" }}</span>{% endif %}
      </td>
      <td>{{ item.kind }}</td>
      <td><code>{{ item.file }}:{{ item.line }}</code></td>
      <td>{{ item.depth }}</td>
      <td{% if item.confidence == name_only %} class="approx"{% endif %}>{{ item.confidence }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<div class="panel">
  <div class="panel-header">🔗 Call Graph</div>
  <div class="mermaid-box">
    <pre class="mermaid">
{{ mermaid }}
    </pre>
  </div>
</div>

<footer>Generated by security-radar v0.2.2</footer>

<script type="module">
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
  mermaid.initialize({ startOnLoad: true, theme: "default" });
</script>
</body>
</html>
