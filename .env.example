# security-radar — AI triage (`radar triage`). Optional, opt-in feature.
# Copy this file to `.env` and fill OPENAI_API_KEY. `.env` is gitignored (never committed).
# These vars are ONLY read by `radar triage`; `radar scan` / `build` / `impact` ignore them.

# Required — OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — model. Default: gpt-4o-mini (cheap, fast, good enough for triage).
# Use gpt-4o for stronger exploitability reasoning at higher cost.
RADAR_AI_MODEL=gpt-4o-mini

# Optional — API base URL. Override for Azure OpenAI, a proxy, or a local
# OpenAI-compatible server (e.g. Ollama). Default is the public OpenAI API.
OPENAI_BASE_URL=https://api.openai.com/v1
